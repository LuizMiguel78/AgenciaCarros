@page
@model atividadehj.Views.Funcionario.IndexModel
@{
}
<!DOCTYPE html>
<html>
<head>
    <style>
        table {
            border-collapse: collapse;
            width: 1190px;
            margin-top: 10px;
        }

        th, td {
            border: 1px solid #ccc;
            padding: 8px;
        }
    </style>
</head>
<body>

    <input type="number" id="codigo" placeholder="Código">
    <input type="text" id="nome" placeholder="nome">
    <input type="text" id="sexo" placeholder="sexo">
    <input type="text" id="cidade" placeholder="cidade">
    <input type="text" id="estado" placeholder="estado">
    <input type="text" id="funcao" placeholder="funcao">
    <button onclick="adicionar()">Adicionar</button>

    <table id="tabela">
        <tr>
            <th>Código</th>
            <th>Nome</th>
            <th>Sexo</th>
            <th>Cidade</th>
            <th>Estado</th>
            <th>Funcão</th>
        </tr>
    </table>

    <script>
        function adicionar() {
          const codigo = document.getElementById("codigo").value;
          const nome = document.getElementById("nome").value;
          const sexo = document.getElementById("sexo").value;
          const cidade = document.getElementById("cidade").value;
          const estado = document.getElementById("estado").value;
          const funcao = document.getElementById("funcao").value;

          // cria a linha
          const linha = document.createElement("tr");

          // cria células
          const colunaCodigo = document.createElement("td");
          colunaCodigo.textContent = codigo;

          const colunaNome = document.createElement("td");
          colunaNome.textContent = nome;

          const colunaSexo = document.createElement("td");
          colunaSexo.textContent = sexo;

          const colunaCidade = document.createElement("td");
          colunaCidade.textContent = cidade;

          const colunaEstado = document.createElement("td");
          colunaEstado.textContent = estado;

          const colunaFuncao = document.createElement("td");
          colunaFuncao.textContent = funcao;
          // adiciona células na linha
          linha.appendChild(colunaCodigo);
          linha.appendChild(colunaNome);
          linha.appendChild(colunaSexo);
          linha.appendChild(colunaCidade);
          linha.appendChild(colunaEstado);
          linha.appendChild(colunaFuncao);

          // adiciona linha na tabela
          document.getElementById("tabela").appendChild(linha);

          // limpa inputs
          document.getElementById("codigo").value = "";
          document.getElementById("nome").value = "";
          document.getElementById("sexo").value = "";
          document.getElementById("cidade").value = "";
          document.getElementById("estado").value = "";
          document.getElementById("funcao").value = "";
        }
    </script>

</body>
</html>